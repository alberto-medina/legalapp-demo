<ConsultaTipoScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 20

        canvas.before:
            Color:
                rgba: 0.07, 0.08, 0.1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Tipo de Consulta"
            font_size: 26
            color: 1,1,1,1

        Button:
            text: "Consulta Rápida"
            on_release: root.seleccionar_tipo()

        Button:
            text: "Consulta Completa"
            on_release: root.seleccionar_tipo()
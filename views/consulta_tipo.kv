<ConsultaTipoScreen>:

    BoxLayout:
        orientation: "vertical"

        canvas.before:
            Color:
                rgba: 0.00, 0.02, 0.12, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # TOPBAR
        BoxLayout:
            size_hint_y: None
            height: 56
            padding: [16, 8, 16, 8]
            canvas.before:
                Color:
                    rgba: 0.00, 0.04, 0.20, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "<"
                size_hint_x: None
                width: 36
                font_size: 20
                bold: True
                background_color: 0, 0, 0, 0
                color: 0.99, 0.84, 0.00, 1
                on_release: root.volver()

            Label:
                text: "TIPO DE CONSULTA"
                font_size: 16
                bold: True
                color: 0.99, 0.84, 0.00, 1
                halign: "left"
                text_size: self.size

        # BANNER ESTADO
        BoxLayout:
            size_hint_y: None
            height: 40
            padding: [16, 6]
            canvas.before:
                Color:
                    rgba: 0.02, 0.04, 0.16, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                id: lbl_banner
                text: ""
                font_size: 12
                bold: True
                halign: "center"
                text_size: self.size

        # SERVICIOS
        BoxLayout:
            orientation: "vertical"
            padding: [16, 16, 16, 10]
            spacing: 14

            # CHAT
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: 88
                spacing: 4
                Button:
                    id: btn_chat
                    text: "Chat"
                    size_hint_y: None
                    height: 60
                    bold: True
                    font_size: 15
                    background_color: 0.18, 0.45, 0.85, 1
                    color: 1, 1, 1, 1
                    on_release: root.seleccionar("chat")
                Label:
                    id: lbl_chat_estado
                    text: ""
                    size_hint_y: None
                    height: 20
                    font_size: 11
                    halign: "center"
                    text_size: self.size

            # VIDEO
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: 88
                spacing: 4
                Button:
                    id: btn_video
                    text: "Videollamada"
                    size_hint_y: None
                    height: 60
                    bold: True
                    font_size: 15
                    background_color: 0.18, 0.45, 0.85, 1
                    color: 1, 1, 1, 1
                    on_release: root.seleccionar("video")
                Label:
                    id: lbl_video_estado
                    text: ""
                    size_hint_y: None
                    height: 20
                    font_size: 11
                    halign: "center"
                    text_size: self.size

            # URGENTE
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: 88
                spacing: 4
                Button:
                    id: btn_urgente
                    text: "URGENTE"
                    size_hint_y: None
                    height: 60
                    bold: True
                    font_size: 15
                    background_color: 0.75, 0.18, 0.18, 1
                    color: 1, 1, 1, 1
                    on_release: root.seleccionar("urgente")
                Label:
                    id: lbl_urgente_estado
                    text: ""
                    size_hint_y: None
                    height: 20
                    font_size: 11
                    halign: "center"
                    text_size: self.size

            Widget:

        # FOOTER
        Button:
            text: "Volver"
            size_hint_y: None
            height: 48
            font_size: 13
            background_color: 0.04, 0.06, 0.22, 1
            color: 0.70, 0.72, 0.85, 1
            on_release: root.volver()

<ConsultaTipoScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        BoxLayout:
            size_hint_y: None
            height: 60

            Button:
                text: "←"
                size_hint_x: None
                width: 50
                on_release: root.volver()

            Label:
                text: "Tipo de Consulta"

        Button:
            text: "Civil"
            on_release: root.seleccionar("Civil")

        Button:
            text: "Penal"
            on_release: root.seleccionar("Penal")
<ConsultaTipoScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 15

        Button:
            text: "← Volver"
            size_hint_y: None
            height: 50
            on_release: root.volver()

        Label:
            text: "Tipo de servicio"
            size_hint_y: None
            height: 40

        Button:
            text: "Chat"
            on_release: root.seleccionar("chat")

        Button:
            text: "Videollamada"
            on_release: root.seleccionar("video")

        Button:
            text: "Urgente"
            on_release: root.seleccionar("urgente")
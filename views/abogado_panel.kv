<AbogadoPanelScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        BoxLayout:
            size_hint_y: None
            height: 50
            spacing: 10

            Button:
                text: "← Salir"
                on_release: root.volver()

            Button:
                text: "Perfil"
                on_release: app.root.current = "perfil"

        Label:
            text: "Panel Abogado"
            size_hint_y: None
            height: 40

        ScrollView:
            BoxLayout:
                id: lista
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
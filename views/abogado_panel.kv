<AbogadoPanelScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        Button:
            text: "← Volver"
            size_hint_y: None
            height: 50
            on_release: root.volver()

        Label:
            text: "Panel Abogado"
            size_hint_y: None
            height: 40

        ScrollView:
            do_scroll_x: False

            BoxLayout:
                id: lista
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: 10
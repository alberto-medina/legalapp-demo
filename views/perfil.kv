<PerfilScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        canvas.before:
            Color:
                rgba: 0.05, 0.06, 0.08, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # HEADER
        BoxLayout:
            size_hint_y: None
            height: 60

            Button:
                text: "←"
                size_hint_x: None
                width: 50
                on_release: root.volver()

            Label:
                text: "Perfil"
                color: 1,1,1,1

        # DATOS
        BoxLayout:
            orientation: "vertical"
            spacing: 10
            size_hint_y: None
            height: 200

            TextInput:
                id: nombre
                hint_text: "Nombre"
                readonly: True
                size_hint_y: None
                height: 40

            TextInput:
                id: email
                hint_text: "Email"
                readonly: True
                size_hint_y: None
                height: 40

            TextInput:
                id: telefono
                hint_text: "Teléfono"
                readonly: True
                size_hint_y: None
                height: 40
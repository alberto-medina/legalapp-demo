<PerfilScreen>:
    BoxLayout:
        orientation: "vertical"

        canvas.before:
            Color:
                rgba: 0.10, 0.12, 0.20, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Perfil"
            size_hint_y: None
            height: 50
            color: 1,1,1,1
            bold: True

        ScrollView:
            BoxLayout:
                orientation: "vertical"
                padding: 20
                spacing: 10
                size_hint_y: None
                height: self.minimum_height

                TextInput:
                    id: nombre
                    hint_text: "Nombre"
                    size_hint_y: None
                    height: 50

                TextInput:
                    id: telefono
                    hint_text: "Telefono"
                    size_hint_y: None
                    height: 50

                TextInput:
                    id: foto
                    hint_text: "URL Foto"
                    size_hint_y: None
                    height: 50

                TextInput:
                    id: matricula
                    hint_text: "Matricula"
                    size_hint_y: None
                    height: 50

                TextInput:
                    id: experiencia
                    hint_text: "Años de experiencia"
                    size_hint_y: None
                    height: 50

                TextInput:
                    id: descripcion
                    hint_text: "Descripcion"
                    size_hint_y: None
                    height: 80

                Button:
                    text: "Guardar"
                    size_hint_y: None
                    height: 50
                    background_color: 0.20, 0.60, 1, 1
                    on_release: root.guardar()
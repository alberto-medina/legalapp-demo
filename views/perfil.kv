<PerfilScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 15
        spacing: 10

        Button:
            text: "← Volver"
            size_hint_y: None
            height: 50
            on_release: root.volver()

        Label:
            text: "Perfil"
            size_hint_y: None
            height: 40

        Image:
            id: img
            source: ""
            size_hint_y: None
            height: 120

        TextInput:
            id: foto
            hint_text: "Ruta de imagen (ej: foto.jpg)"
            size_hint_y: None
            height: 50

        TextInput:
            id: nombre
            hint_text: "Nombre"
            size_hint_y: None
            height: 50

        TextInput:
            id: email
            readonly: True
            size_hint_y: None
            height: 50

        TextInput:
            id: telefono
            hint_text: "Teléfono"
            size_hint_y: None
            height: 50

        TextInput:
            id: especialidad
            hint_text: "Especialidad (abogado)"
            size_hint_y: None
            height: 50

        TextInput:
            id: descripcion
            hint_text: "Descripción"
            size_hint_y: None
            height: 80

        Button:
            text: "Guardar cambios"
            size_hint_y: None
            height: 50
            on_release: root.guardar()
<ResenaScreen>:

    BoxLayout:
        orientation: "vertical"

        canvas.before:
            Color:
                rgba: 0.00, 0.02, 0.12, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # TOPBAR
        BoxLayout:
            size_hint_y: None
            height: 56
            padding: [16, 8, 16, 8]
            canvas.before:
                Color:
                    rgba: 0.00, 0.04, 0.20, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "CALIFICA TU CONSULTA"
                font_size: 16
                bold: True
                color: 0.99, 0.84, 0.00, 1
                halign: "center"
                text_size: self.size

        BoxLayout:
            orientation: "vertical"
            padding: [20, 24, 20, 16]
            spacing: 20

            Label:
                id: lbl_abogado_resena
                text: ""
                font_size: 14
                color: 0.70, 0.72, 0.85, 1
                size_hint_y: None
                height: 30
                halign: "center"
                text_size: self.size

            # PUNTAJE NUMERICO (1-5)
            Label:
                text: "Puntaje del 1 al 5"
                font_size: 13
                bold: True
                color: 0.50, 0.55, 0.70, 1
                size_hint_y: None
                height: 26
                halign: "center"
                text_size: self.size

            BoxLayout:
                id: estrellas_box
                size_hint_y: None
                height: 54
                spacing: 8
                padding: [30, 2]

            # COMENTARIO
            Label:
                text: "Comentario (opcional)"
                font_size: 13
                bold: True
                color: 0.50, 0.55, 0.70, 1
                size_hint_y: None
                height: 26
                halign: "left"
                text_size: self.size

            TextInput:
                id: input_comentario
                hint_text: "Contanos como fue tu experiencia..."
                multiline: True
                size_hint_y: None
                height: 100
                background_color: 0.04, 0.06, 0.22, 1
                foreground_color: 0.92, 0.94, 1.00, 1
                hint_text_color: 0.40, 0.45, 0.60, 1
                cursor_color: 0.99, 0.84, 0.00, 1
                padding: [12, 12]

            Widget:
                size_hint_y: None
                height: 10

            Button:
                text: "ENVIAR RESENA"
                size_hint_y: None
                height: 54
                bold: True
                font_size: 15
                background_color: 0.99, 0.84, 0.00, 1
                color: 0.00, 0.02, 0.12, 1
                on_release: root.enviar_resena()

            Button:
                text: "Omitir"
                size_hint_y: None
                height: 40
                font_size: 13
                background_color: 0, 0, 0, 0
                color: 0.45, 0.50, 0.65, 1
                on_release: root.omitir()

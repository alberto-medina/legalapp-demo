<DashboardScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 20

        canvas.before:
            Color:
                rgba: 0.07, 0.08, 0.1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Bienvenido"
            font_size: 28
            color: 1,1,1,1

        Button:
            text: "Nueva Consulta"
            size_hint_y: None
            height: 60
            background_color: 0.2, 0.6, 1, 1
            on_release: root.nueva_consulta()

        Button:
            text: "Historial"
            size_hint_y: None
            height: 60
            background_color: 0.3, 0.3, 0.35, 1
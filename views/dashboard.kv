<DashboardScreen>:
    BoxLayout:
        orientation: "vertical"

        canvas.before:
            Color:
                rgba: 0.10, 0.12, 0.20, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: 60
            padding: 10

            Label:
                text: "LEGAL APP"
                color: 1,1,1,1
                bold: True

        BoxLayout:
            orientation: "vertical"
            padding: 20
            spacing: 15

            Button:
                text: "Nueva Consulta"
                size_hint_y: None
                height: 60
                background_color: 0.20, 0.60, 1, 1
                on_release: root.nueva_consulta()

            Button:
                text: "Historial"
                size_hint_y: None
                height: 60
                background_color: 0.15, 0.17, 0.25, 1
                on_release: root.ver_historial()

            Button:
                text: "Perfil"
                size_hint_y: None
                height: 60
                background_color: 0.15, 0.17, 0.25, 1
                on_release: root.ir_perfil()
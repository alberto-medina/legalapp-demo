#:import ButtonBehavior kivy.uix.behaviors.ButtonBehavior

<InfoCard@BoxLayout>:
    orientation: "vertical"
    size_hint_y: None
    height: 140
    padding: 15
    spacing: 8

    canvas.before:
        Color:
            rgba: 0.15, 0.17, 0.25, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [15]


<PagoScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 15
        spacing: 15

        canvas.before:
            Color:
                rgba: 0.10, 0.12, 0.20, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # HEADER
        Label:
            text: "Confirmar consulta"
            size_hint_y: None
            height: 60
            color: 1,1,1,1
            bold: True

        # RESUMEN
        InfoCard:
            Label:
                text: "Especialidad"
                color: 0.7,0.7,0.7,1
            Label:
                id: lbl_area
                text: "-"
                color: 1,1,1,1
                bold: True

        InfoCard:
            Label:
                text: "Abogado"
                color: 0.7,0.7,0.7,1
            Label:
                id: lbl_abogado
                text: "-"
                color: 1,1,1,1
                bold: True

        InfoCard:
            Label:
                text: "Servicio"
                color: 0.7,0.7,0.7,1
            Label:
                id: lbl_tipo
                text: "-"
                color: 1,1,1,1
                bold: True

        InfoCard:
            Label:
                text: "Total a pagar"
                color: 0.7,0.7,0.7,1
            Label:
                id: lbl_precio
                text: "$0"
                color: 0,1,0,1
                font_size: 20
                bold: True

        # BOTÓN PRINCIPAL
        Button:
            text: "Confirmar y comenzar consulta"
            size_hint_y: None
            height: 60
            background_color: 0.20, 0.60, 1, 1
            on_release: root.pagar()

        # VOLVER
        Button:
            text: "Volver"
            size_hint_y: None
            height: 50
            background_color: 0.15, 0.17, 0.25, 1
            on_release: root.manager.current = "abogados"
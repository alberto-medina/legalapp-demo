<PagoScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        Button:
            text: "← Volver"
            size_hint_y: None
            height: 50
            on_release: root.volver()

        Label:
            text: "Confirmar pago"
            size_hint_y: None
            height: 40

        Label:
            id: precio
            text: ""
            size_hint_y: None
            height: 40

        Button:
            text: "Pagar"
            size_hint_y: None
            height: 60
            on_release: root.pagar()
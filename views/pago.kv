<PagoScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 20

        canvas.before:
            Color:
                rgba: 0.07, 0.08, 0.1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Confirmar Pago"
            font_size: 26
            color: 1,1,1,1

        Label:
            text: "Consulta: $5000"
            color: 1,1,1,1

        Button:
            text: "Pagar Ahora"
            background_color: 0.2, 0.7, 0.3, 1
            on_release: root.pagar()
<ChatScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        Button:
            text: "← Volver"
            size_hint_y: None
            height: 50
            on_release: root.volver()

        ScrollView:
            size_hint_y: 0.8

            Label:
                id: chat_box
                text: ""
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None

        BoxLayout:
            size_hint_y: None
            height: 50
            spacing: 5

            TextInput:
                id: input

            Button:
                text: "Enviar"
                size_hint_x: 0.3
                on_release: root.enviar()
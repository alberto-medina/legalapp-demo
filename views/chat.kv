<ChatScreen>:

    BoxLayout:
        orientation: "vertical"
        spacing: 5
        padding: 5

        Button:
            text: "← Volver"
            size_hint_y: None
            height: 40
            on_release: root.volver()

        ScrollView:
            GridLayout:
                id: chat_box
                cols: 1
                spacing: 5
                size_hint_y: None
                height: self.minimum_height

        BoxLayout:
            size_hint_y: None
            height: 50
            spacing: 5

            TextInput:
                id: input_mensaje
                hint_text: "Escribí un mensaje..."
                multiline: False

            Button:
                text: "📎"
                size_hint_x: 0.2
                on_release: root.adjuntar()

            Button:
                text: "Enviar"
                size_hint_x: 0.3
                on_release: root.enviar()
<ChatScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        Button:
            text: "← Volver"
            size_hint_y: None
            height: 50
            on_release: root.volver()

        Label:
            id: chat_box
            text: "Chat"
            size_hint_y: 0.8

        TextInput:
            id: input
            size_hint_y: None
            height: 50

        Button:
            text: "Enviar"
            size_hint_y: None
            height: 50
            on_release: root.enviar()
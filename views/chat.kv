<ChatScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 10

        Button:
            text: "← Volver al Dashboard"
            size_hint_y: None
            height: 40
            on_release: root.volver_dashboard()

        Label:
            text: "Chat con abogado"
            size_hint_y: None
            height: 40

        ScrollView:
            BoxLayout:
                id: chat_box
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height

        TextInput:
            hint_text: "Escribí tu mensaje..."
            size_hint_y: None
            height: 50

        Button:
            text: "Enviar"
            size_hint_y: None
            height: 50
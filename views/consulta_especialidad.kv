<ConsultaEspecialidadScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 15

        Button:
            text: "← Volver"
            size_hint_y: None
            height: 50
            on_release: root.volver()

        Label:
            text: "Área legal"
            size_hint_y: None
            height: 40

        Button:
            text: "Civil"
            on_release: root.seleccionar("Civil")

        Button:
            text: "Penal"
            on_release: root.seleccionar("Penal")

        Button:
            text: "Laboral"
            on_release: root.seleccionar("Laboral")

        Button:
            text: "Familia"
            on_release: root.seleccionar("Familia")
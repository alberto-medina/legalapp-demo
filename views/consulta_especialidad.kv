#:import ButtonBehavior kivy.uix.behaviors.ButtonBehavior

<EspecialidadCard@ButtonBehavior+BoxLayout>:
    orientation: "horizontal"
    size_hint_y: None
    height: 88
    padding: [14, 12]
    spacing: 14
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [14]
        Color:
            rgba: 0.88, 0.90, 0.93, 1
        Line:
            rounded_rectangle: [self.x+1, self.y+1, self.width-2, self.height-2, 14]
            width: 0.8

<ConsultaEspecialidadScreen>:

    BoxLayout:
        orientation: "vertical"

        canvas.before:
            Color:
                rgba: 0.96, 0.97, 0.98, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: 58
            padding: [12, 10, 16, 10]
            canvas.before:
                Color:
                    rgba: 0.00, 0.04, 0.22, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "<"
                size_hint_x: None
                width: 36
                font_size: 22
                bold: True
                background_color: 0, 0, 0, 0
                color: 0.99, 0.84, 0.00, 1
                on_release: root.volver()

            Label:
                text: "AREA LEGAL"
                font_size: 16
                bold: True
                color: 1, 1, 1, 1
                halign: "left"
                text_size: self.size

        Label:
            text: "Selecciona tu especialidad"
            font_size: 13
            color: 0.45, 0.50, 0.60, 1
            size_hint_y: None
            height: 34
            halign: "center"
            text_size: self.size

        ScrollView:
            BoxLayout:
                orientation: "vertical"
                padding: [16, 8, 16, 16]
                spacing: 12
                size_hint_y: None
                height: self.minimum_height

                EspecialidadCard:
                    on_release: root.seleccionar("Familiar")
                    AsyncImage:
                        source: "assets/familia.png"
                        size_hint_x: None
                        width: 60
                        allow_stretch: True
                    BoxLayout:
                        orientation: "vertical"
                        Label:
                            text: "Derecho Familiar"
                            bold: True
                            font_size: 15
                            color: 0.08, 0.12, 0.28, 1
                            halign: "left"
                            text_size: self.size
                        Label:
                            text: "Divorcios, custodia, herencias"
                            font_size: 12
                            color: 0.45, 0.50, 0.60, 1
                            halign: "left"
                            text_size: self.size

                EspecialidadCard:
                    on_release: root.seleccionar("Laboral")
                    AsyncImage:
                        source: "assets/laboral.png"
                        size_hint_x: None
                        width: 60
                        allow_stretch: True
                    BoxLayout:
                        orientation: "vertical"
                        Label:
                            text: "Derecho Laboral"
                            bold: True
                            font_size: 15
                            color: 0.08, 0.12, 0.28, 1
                            halign: "left"
                            text_size: self.size
                        Label:
                            text: "Despidos, contratos, ART"
                            font_size: 12
                            color: 0.45, 0.50, 0.60, 1
                            halign: "left"
                            text_size: self.size

                EspecialidadCard:
                    on_release: root.seleccionar("Penal")
                    AsyncImage:
                        source: "assets/penal.png"
                        size_hint_x: None
                        width: 60
                        allow_stretch: True
                    BoxLayout:
                        orientation: "vertical"
                        Label:
                            text: "Derecho Penal"
                            bold: True
                            font_size: 15
                            color: 0.08, 0.12, 0.28, 1
                            halign: "left"
                            text_size: self.size
                        Label:
                            text: "Denuncias, defensa, causas"
                            font_size: 12
                            color: 0.45, 0.50, 0.60, 1
                            halign: "left"
                            text_size: self.size

                EspecialidadCard:
                    on_release: root.seleccionar("Civil")
                    AsyncImage:
                        source: "assets/civil.png"
                        size_hint_x: None
                        width: 60
                        allow_stretch: True
                    BoxLayout:
                        orientation: "vertical"
                        Label:
                            text: "Derecho Civil"
                            bold: True
                            font_size: 15
                            color: 0.08, 0.12, 0.28, 1
                            halign: "left"
                            text_size: self.size
                        Label:
                            text: "Danos, contratos, inmuebles"
                            font_size: 12
                            color: 0.45, 0.50, 0.60, 1
                            halign: "left"
                            text_size: self.size

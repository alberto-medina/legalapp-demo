<ConsultaEspecialidadScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20

        BoxLayout:
            size_hint_y: None
            height: 60

            Button:
                text: "←"
                size_hint_x: None
                width: 50
                on_release: root.volver()

            Label:
                text: "Especialidad"

        Button:
            text: "Familia"
            on_release: root.seleccionar("Familia")

        Button:
            text: "Laboral"
            on_release: root.seleccionar("Laboral")
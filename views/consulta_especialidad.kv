<ConsultaEspecialidadScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 20

        canvas.before:
            Color:
                rgba: 0.07, 0.08, 0.1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Especialidad"
            font_size: 26
            color: 1,1,1,1

        Button:
            text: "Derecho Civil"
            on_release: root.seleccionar_especialidad()

        Button:
            text: "Derecho Penal"
            on_release: root.seleccionar_especialidad()
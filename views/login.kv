<LoginScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 40
        spacing: 20

        Label:
            text: "LEGAL APP"

        TextInput:
            id: email
            hint_text: "Email"

        TextInput:
            id: password
            hint_text: "Password"
            password: True

        Button:
            text: "Ingresar"
            on_release: root.go_to_dashboard()

        Button:
            text: "Crear cuenta"
            on_release: root.go_to_register()
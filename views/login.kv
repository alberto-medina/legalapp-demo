<LoginScreen>:
    BoxLayout:
        orientation: "vertical"

        canvas.before:
            Color:
                rgba: 0.05, 0.06, 0.08, 1
            Rectangle:
                pos: self.pos
                size: self.size

        padding: 30
        spacing: 20

        Widget:
            size_hint_y: None
            height: 40

        # LOGO / NOMBRE
        Label:
            text: "Legal App"
            font_size: 32
            bold: True
            color: 1,1,1,1
            size_hint_y: None
            height: 50

        Label:
            text: "Accede a tu cuenta"
            color: 0.7,0.7,0.7,1
            size_hint_y: None
            height: 30

        Widget:
            size_hint_y: None
            height: 20

        # FORM CARD
        BoxLayout:
            orientation: "vertical"
            padding: 20
            spacing: 15
            size_hint_y: None
            height: 260

            canvas.before:
                Color:
                    rgba: 0.12, 0.14, 0.18, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15]

            TextInput:
                id: email
                hint_text: "Email"
                multiline: False
                size_hint_y: None
                height: 45
                background_color: 0.2,0.2,0.25,1
                foreground_color: 1,1,1,1

            TextInput:
                id: password
                hint_text: "Contrasena"
                password: True
                multiline: False
                size_hint_y: None
                height: 45
                background_color: 0.2,0.2,0.25,1
                foreground_color: 1,1,1,1

            Label:
                id: error
                text: ""
                color: 1,0.3,0.3,1
                size_hint_y: None
                height: 20

            Button:
                text: "Ingresar"
                size_hint_y: None
                height: 50
                background_color: 0.2, 0.6, 1, 1
                on_release: root.login()

        Widget:
            size_hint_y: None
            height: 10

        Button:
            text: "Crear cuenta"
            size_hint_y: None
            height: 45
            background_color: 0.2,0.2,0.25,1
            on_release: root.go_register()